<div id="chatScreen">
    <div class="chat-header">
        <i class="bi bi-robot fs-5"></i>
        <span>Ojaly Chat Bot</span>
        <span class="status-dot"></span>
        <span class="badge-model">AI Assistant</span>
    </div>

    <div class="chat-messages" id="chatMessages">
        <div class="message bot-message">
            <div class="bubble">👋 مرحباً! أنا <strong>Ojaly</strong>، مساعدك الذكي. كيف يمكنني مساعدتك اليوم؟</div>
        </div>
    </div>

    <div class="chat-input-area">
        <div class="input-group">
            <button class="btn-send" id="sendBtn" onclick="sendMessage()">
                <i class="bi bi-send-fill"></i>
            </button>
            <input type="text" id="userInput" class="form-control" placeholder="اكتب رسالتك هنا..." autocomplete="off" />
        </div>
    </div>
</div>
